#include <Adafruit_NeoPixel.h>
Adafruit_NeoPixel pixels(1, 48, NEO_GRB + NEO_KHZ800);
void setup() {
  pixels.begin();
}
void loop() {
  for(int i=0; i<=255; i++){
    pixels.setPixelColor(0, pixels.Color(i,0,0));
    pixels.show();
    delay(5);
  }
  for(int i=255; i>=0; i--){
    pixels.setPixelColor(0, pixels.Color(i,0,0));
    pixels.show();
    delay(5);
  }
}
