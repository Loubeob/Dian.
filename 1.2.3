#include <I2S.h>
#include <math.h>
#define B 4
#define W 5
#define D 18
#define PI 3.14159265
#define BOOT_KEY 0
int mode = 0;
void setup() {
  I2S.begin(I2S_PHILIPS_MODE, 44100, 16);
  I2S.setPins(B, W, D);
  pinMode(BOOT_KEY, INPUT_PULLUP);
}

void loop() {
  static int c=0;
  if(digitalRead(BOOT_KEY) == LOW){
    mode = (mode + 1) % 3;
    delay(50);
  }

  int l = 8000 * sin(2 * PI * 1000 * c / 44100.0);
  int r = 8000 * sin(2 * PI * 4000 * c / 44100.0);

  if(mode == 0){
    I2S.write(l);
    I2S.write(0);
  }else if(mode == 1){
    I2S.write(0);
    I2S.write(r);
  }else{
    I2S.write(l);
    
    I2S.write(r);
  }
  c++;
}
